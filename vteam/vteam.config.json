{
  "baseBranch": "main",
  "platform": "github",
  "worktreeDir": ".vteam-worktrees",
  "agents": {
    "code-reviewer": {
      "model": "sonnet",
      "scanPaths": ["src/"],
      "excludePaths": ["node_modules/", "dist/"]
    },
    "refactorer": {
      "model": "sonnet",
      "autoMR": true,
      "mrLabels": ["vteam", "automated"]
    }
  },
  "tasks": {
    "maxRetries": 3
  }
}
