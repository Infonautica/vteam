{
  "name": "vteam",
  "version": "0.2.0",
  "description": "Virtual development team framework powered by Claude Code",
  "type": "module",
  "bin": {
    "vteam": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/templates dist/templates",
    "dev": "tsx src/bin.ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "claude",
    "ai",
    "code-review",
    "refactoring",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
